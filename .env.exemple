# Email pour Let's Encrypt (renouvellement TLS automatique)
LETSENCRYPT_EMAIL=ton.email@example.com

# Secret partagé HMAC des webhooks GitHub (généré : openssl rand -hex 32)
# À reporter à l'identique dans chaque webhook GitHub des projets.
WEBHOOK_SECRET=change-me

# Chemin ABSOLU de la clé privée deployer sur le VPS (clé sans passphrase, accès
# lecture aux repos). Pas de ~ : docker compose ne l'expand pas.
DEPLOYER_SSH_KEY=/home/user/.ssh/deployer
