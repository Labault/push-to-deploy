{
	# Email pour Let's Encrypt (renouvellement automatique)
	email {$LETSENCRYPT_EMAIL}
}

# ── Snippet headers de sécurité globaux ────────────────────────────────
(security_headers) {
	header {
		# HSTS 1 an, inclut sous-domaines, preload-ready
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		# Anti MIME-sniffing
		X-Content-Type-Options "nosniff"
		# Anti-clickjacking
		X-Frame-Options "SAMEORIGIN"
		# Referrer policy raisonnable
		Referrer-Policy "strict-origin-when-cross-origin"
		# Permissions policy minimaliste (pas de mic/camera/geoloc par défaut)
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		# Masque la stack
		-Server
	}
}

# ── redflagbingo.fun ───────────────────────────────────────────────────
redflagbingo.fun {
	import security_headers
	encode zstd gzip
	reverse_proxy rfb_app:80 {
		# Préserve les infos d'origine pour Symfony/FrankenPHP
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up Host {host}
	}
}

# ── humelis.labault.dev ────────────────────────────────────────────
humelis.labault.dev {
        import security_headers
        encode zstd gzip
        reverse_proxy humelis_app:80 {
                header_up X-Real-IP {remote_host}
                header_up X-Forwarded-Proto {scheme}
                header_up Host {host}
        }
}

# ── labault.dev ────────────────────────────────────────────
labault.dev {
    import security_headers
    root * /srv/portfolio
    file_server

    # Compression gzip/brotli (perf sur le HTML lourd)
    encode gzip

    # Cache navigateur (optionnel, utile pour les fonts Google)
    header /index.html Cache-Control "no-cache, must-revalidate"
}

# Redirection www → non-www
www.labault.dev {
    redir https://labault.dev{uri} permanent
}

# ── hush.labault.dev ────────────────────────────────────────────
hush.labault.dev {
    encode gzip zstd

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), camera=(), microphone=()"
        -Server
    }

    reverse_proxy hush-web-prod:80 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up Host {host}
    }

    log {
        output file /var/log/caddy/hush.log {
            roll_size 10mb
            roll_keep 5
        }
        format console
    }
}

